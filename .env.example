# Repo B no usa variables de entorno propias.
# El único secret de este repo vive en GitHub → Settings → Actions → Secrets:
#
#   VERCEL_DEPLOY_HOOK_URL  ← URL del Deploy Hook del proyecto Vercel del Repo A
#
# (Lo usa .github/workflows/vercel-redeploy.yml para disparar un rebuild
#  automático cuando se commitea contenido a main.)
VERCEL_DEPLOY_HOOK_URL=
